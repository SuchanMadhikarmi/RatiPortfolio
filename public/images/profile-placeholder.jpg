<svg xmlns="http://www.w3.org/2000/svg" width="600" height="750" viewBox="0 0 600 750">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C9A84C;stop-opacity:0.3" />
      <stop offset="50%" style="stop-color:#1a1a1a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#090909;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="750" fill="url(#bg)"/>
  <text x="300" y="375" font-family="Georgia, serif" font-size="120" fill="#F5F0E8" fill-opacity="0.15" text-anchor="middle" dominant-baseline="middle">RM</text>
  <text x="300" y="430" font-family="sans-serif" font-size="14" fill="#6B6B6B" text-anchor="middle" letter-spacing="4">REPLACE WITH PHOTO</text>
</svg>
